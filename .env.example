# サーバー設定
PORT=

# データベース接続(SupabaseのPostgres接続文字列)
DATABASE_URL=

# Supabase Auth連携
# SUPABASE_URLはSupabase AuthへのプロキシだけでなくJWT検証(JWKS取得)にも使う。
# JWKSは {SUPABASE_URL}/auth/v1/.well-known/jwks.json から自動取得するため、
# JWTシークレットを別途設定する必要はない(JWT Signing Keys/ES256方式前提)。
SUPABASE_URL=
# Settings > API Keys の Publishable key(sb_publishable_...、旧anon key相当)
SUPABASE_PUBLISHABLE_KEY=

# CORS許可オリジン(フロントエンドのURL、カンマ区切りで複数可)
ALLOWED_ORIGINS=
